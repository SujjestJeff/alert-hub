# ─────────────────────────────────────────────────────────────
#  Alertbox configuration
#  Copy this file to `.env` and fill it in:  cp .env.example .env
#  Never commit your real `.env` — it holds secrets. (It's gitignored.)
# ─────────────────────────────────────────────────────────────


# ── Server ───────────────────────────────────────────────────

# Port to serve on. Default 3000.
PORT=3000

# Where the SQLite database lives (tokens + config).
# Local dev: ./data/alertbox.db
# Docker:    /data/alertbox.db   <- set this in docker-compose, so it lands on the volume
DATABASE_PATH=./data/alertbox.db

# `production` on a real deploy (also makes the admin login cookie `secure`).
# Leave as `development` for local http://localhost, or login will silently fail.
NODE_ENV=development

# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info


# ── Twitch app (register your own — see the README) ──────────
#  https://dev.twitch.tv/console/apps
#  The Redirect URL in your Twitch app MUST match TWITCH_REDIRECT_URI
#  EXACTLY — same scheme, host, port, and path. This is the #1 setup trap.

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Must be byte-for-byte identical to your Twitch app's OAuth Redirect URL.
TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback

# Your channel login name — the lowercase handle from your Twitch URL.
TWITCH_BROADCASTER_LOGIN=


# ── Admin panel ──────────────────────────────────────────────

# Password for the config panel at http://localhost:3000/
# Make it something that isn't "password".
ADMIN_PASSWORD=

# Random string used to sign the admin login cookie.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=


# ── Overlay security ─────────────────────────────────────────

# Random string that gates your overlay URL so nobody else can
# connect to your alert stream or fire fake alerts.
# Generate one with:  openssl rand -hex 32
# You'll append it to the OBS browser source URL:
#   http://localhost:3000/overlay?token=YOUR_OVERLAY_TOKEN
# NOTE: if this is empty, the overlay fails closed (refuses connections). Fill it in.
OVERLAY_TOKEN=


# ── Development only ─────────────────────────────────────────

# Points EventSub at the Twitch CLI mock server for local testing.
# Leave UNSET in normal use — it defaults to the real Twitch WebSocket URL.
# Do NOT set this to an empty string; either omit the line or give it a real ws:// URL.
# EVENTSUB_WS_URL=ws://127.0.0.1:8080/ws
