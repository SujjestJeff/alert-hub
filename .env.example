# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
DATABASE_PATH=./data/alertbox.db        # in Docker, points at the mounted volume

# --- Twitch app (register your own — see README) ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback
TWITCH_BROADCASTER_LOGIN=                # your channel login name

# --- Admin panel auth (used from Episode 6) ---
ADMIN_PASSWORD=
SESSION_SECRET=                          # random string

# --- Overlay security (used from Episode 4) ---
OVERLAY_TOKEN=                           # random string; gates the overlay URL
